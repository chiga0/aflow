RUN_MANAGER_TOKEN=
RUN_MANAGER_BOOTSTRAP_EMAIL=owner@example.com
RUNTIME_BOOTSTRAP_PASSWORD=
RUN_MANAGER_SESSION_SECRET=
RUN_WORKER_TOKEN=

POSTGRES_DB=agentflow
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=
V2_DATABASE_URL=
V2_QUEUE_URL=redis://redis:6379/0

RUNTIME_BIND=127.0.0.1
V2_WORKER_CONCURRENCY=2
V2_WORKER_REPLICAS=2
TEMPORAL_TASK_QUEUE=agentflow-v2

# For 2C2G VPS, keep this HA profile off-box or reduce worker replicas to 1.
# Recommended: run runtime.local-nas.env.example on NAS/workstation,
# keep the small VPS as reverse proxy or one low-capacity worker.
V2_BACKUP_ENABLED=1
V2_BACKUP_TARGET=/data/backups
V2_ENABLE_REAL_CLI_ADAPTERS=0

# JSON array of production execution units. Examples:
# V2_EXECUTION_UNITS_JSON=[{"unit_id":"docker-local","kind":"docker","adapters":["qwen","codex"],"resources":{"cpu":2,"memory_mb":4096}},{"unit_id":"ecs-hz-a","kind":"ecs","labels":{"region":"cn-hangzhou"},"adapters":["qwen","opencode"]},{"unit_id":"nas-home","kind":"nas","adapters":["fake","qwen"],"features":["workspace","artifacts"]}]
V2_EXECUTION_UNITS_JSON=[]
