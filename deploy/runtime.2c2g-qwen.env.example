# Single-host Docker profile for a 2C2G server running AgentFlow + one real Qwen task.
# This is a constrained personal/demo profile, not a multi-user production profile.

RUN_MANAGER_TOKEN=replace-with-random-token
RUN_MANAGER_BOOTSTRAP_EMAIL=owner@example.com
RUNTIME_BOOTSTRAP_PASSWORD=replace-with-random-password
RUN_MANAGER_BOOTSTRAP_NAME=Owner
RUN_MANAGER_SESSION_SECRET=replace-with-random-session-secret

RUN_MANAGER_WORKER_CAPACITY=1
RUN_MANAGER_LEASE_TTL_SECONDS=60
RUN_MANAGER_DEFAULT_CPUS=1.0
RUN_MANAGER_MAX_CPUS=1.5
RUN_MANAGER_DEFAULT_MEMORY_MB=1024
RUN_MANAGER_MAX_MEMORY_MB=1400
RUN_MANAGER_DEFAULT_PIDS=256
RUN_MANAGER_MAX_PIDS=512
RUN_MANAGER_DEFAULT_TIMEOUT_SECONDS=1800
RUN_MANAGER_MAX_TIMEOUT_SECONDS=3600

RUN_MANAGER_CLEANUP_ENABLED=1
RUN_MANAGER_WORKSPACE_RETENTION_SECONDS=259200
RUN_MANAGER_ARTIFACT_RETENTION_SECONDS=604800
RUN_MANAGER_CLEANUP_INTERVAL_SECONDS=1800

RUNTIME_CPUS=1.75
RUNTIME_MEMORY_LIMIT=1536m
RUNTIME_PIDS_LIMIT=512

V2_AUTO_ADAPTER=qwen
V2_CLI_TIMEOUT_SECONDS=1800
V2_QWEN_CODE_COMMAND=qwen --safe-mode --yolo
QWEN_NODE_PACKAGE=@qwen-code/qwen-code@0.19.11
NODE_IMAGE=public.ecr.aws/docker/library/node:22-bookworm-slim
PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.13-slim

# init_docker_env.py replaces these with absolute host paths.
AGENTFLOW_WORKSPACE_DIR=/absolute/path/to/workspace
QWEN_SETTINGS_FILE=/absolute/path/to/.qwen/settings.json
