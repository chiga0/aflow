RUN_MANAGER_TOKEN=change-me
RUN_MANAGER_WORKER_CAPACITY=1
RUN_MANAGER_LEASE_TTL_SECONDS=60
RUN_MANAGER_DEFAULT_CPUS=1.0
RUN_MANAGER_MAX_CPUS=1.0
RUN_MANAGER_DEFAULT_MEMORY_MB=1024
RUN_MANAGER_MAX_MEMORY_MB=1024
RUN_MANAGER_DEFAULT_PIDS=512
RUN_MANAGER_MAX_PIDS=512
RUN_MANAGER_DEFAULT_TIMEOUT_SECONDS=3600
RUN_MANAGER_MAX_TIMEOUT_SECONDS=3600
RUN_MANAGER_CLEANUP_ENABLED=1
RUN_MANAGER_WORKSPACE_RETENTION_SECONDS=604800
RUN_MANAGER_ARTIFACT_RETENTION_SECONDS=2592000
RUN_MANAGER_CLEANUP_INTERVAL_SECONDS=3600
QWEN_SERVER_TOKEN=change-me-too
QWEN_SERVE_URL=http://127.0.0.1:4170
QWEN_SERVE_TOKEN=change-me-too
QWEN_SERVE_COMMAND=qwen serve --hostname 127.0.0.1 --port 4170 --workspace /var/lib/cloud-agents-runtime/workspace --no-web --require-auth
QWEN_SERVE_CWD=/var/lib/cloud-agents-runtime/workspace
QWEN_SERVE_STARTUP_TIMEOUT=30
QWEN_EXECUTOR_STRATEGY=shared
QWEN_EXECUTOR_HOST=127.0.0.1
QWEN_EXECUTOR_PORT_START=4210
QWEN_EXECUTOR_PORT_END=4310
# For per-run qwen isolation, set QWEN_EXECUTOR_STRATEGY=per_run_process and
# unset QWEN_SERVE_URL/QWEN_SERVE_COMMAND if you do not want a shared daemon.
QWEN_EXECUTOR_COMMAND=qwen serve --hostname {host} --port {port}
QWEN_EXECUTOR_STARTUP_TIMEOUT=20
QWEN_EXECUTOR_STOP_TIMEOUT=5
# For Docker isolation, set QWEN_EXECUTOR_STRATEGY=container and provide either
# QWEN_CONTAINER_IMAGE for the default docker run command or QWEN_CONTAINER_COMMAND
# for a fully custom command template.
QWEN_CONTAINER_COMMAND=
QWEN_CONTAINER_IMAGE=
QWEN_CONTAINER_NETWORK=bridge
QWEN_CONTAINER_CPUS=1
QWEN_CONTAINER_MEMORY_MB=1024
QWEN_CONTAINER_PIDS=256
QWEN_CONTAINER_EXTRA_ARGS=
QWEN_CONTAINER_BUILD=0
QWEN_CONTAINER_BASE_IMAGE=node:22-bookworm-slim
QWEN_CONTAINER_NODE_PACKAGE=@qwen-code/qwen-code@0.19.3
V2_ENABLE_REAL_CLI_ADAPTERS=1
V2_QWEN_CODE_COMMAND=qwen
V2_CODEX_CLI_COMMAND=codex exec -
# OPENAI_API_KEY=configure-through-your-secret-manager
