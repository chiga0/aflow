# Copy to a mode-600 file such as .env.worker-tunnel-hk.
TUNNEL_NAME=ecs-hk
TUNNEL_SSH_TARGET=root@203.0.113.10
TUNNEL_SSH_KEY=/absolute/path/to/worker.pem
TUNNEL_REMOTE_BIND=127.0.0.1
TUNNEL_REMOTE_PORT=18765
TUNNEL_LOCAL_HOST=127.0.0.1
TUNNEL_LOCAL_PORT=8765
TUNNEL_RETRY_SECONDS=5
TUNNEL_STATE_DIR=.runtime/worker-tunnels
